<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ARIA Corp. | 대시보드</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Noto+Sans+KR:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #030810;
        --panel: #050f1a;
        --border: #0d3a5c;
        --accent: #00d4ff;
        --accent2: #ff4444;
        --accent3: #ffcc00;
        --text: #a8d8ea;
        --muted: #3a6b8a;
        --glow: 0 0 20px rgba(0, 212, 255, 0.4);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: "Noto Sans KR", sans-serif;
        min-height: 100vh;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(0, 212, 255, 0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 212, 255, 0.02) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
        z-index: 0;
      }

      header {
        border-bottom: 1px solid var(--border);
        padding: 14px 0;
        background: rgba(5, 15, 26, 0.95);
        backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .header-inner {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-family: "Orbitron", monospace;
        font-weight: 900;
        font-size: 1.1rem;
        color: var(--accent);
        text-shadow: var(--glow);
        letter-spacing: 4px;
      }

      .logo span {
        color: #ff4444;
      }

      nav a {
        font-family: "Share Tech Mono", monospace;
        color: var(--muted);
        text-decoration: none;
        font-size: 0.82rem;
        margin-left: 20px;
        letter-spacing: 1px;
        transition: color 0.2s;
      }

      nav a:hover {
        color: var(--accent);
      }

      .main {
        position: relative;
        z-index: 2;
        max-width: 1000px;
        margin: 0 auto;
        padding: 40px 24px;
      }

      .page-title {
        font-family: "Orbitron", monospace;
        font-size: 1.4rem;
        font-weight: 900;
        color: #fff;
        margin-bottom: 6px;
      }

      .page-sub {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.75rem;
        color: var(--muted);
        letter-spacing: 2px;
        margin-bottom: 36px;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
      }

      @media (max-width: 700px) {
        .grid {
          grid-template-columns: 1fr;
        }
      }

      .panel {
        border: 1px solid var(--border);
        background: var(--panel);
        padding: 24px;
        position: relative;
      }

      .panel::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 3px;
        height: 100%;
        background: linear-gradient(180deg, var(--accent), transparent);
      }

      .panel-label {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.68rem;
        color: var(--accent);
        letter-spacing: 3px;
        margin-bottom: 16px;
      }

      .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid rgba(13, 58, 92, 0.5);
      }

      .info-row:last-child {
        border-bottom: none;
      }

      .info-key {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.75rem;
        color: var(--muted);
        letter-spacing: 1px;
      }

      .info-val {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.82rem;
        color: var(--text);
      }

      .badge {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.7rem;
        padding: 3px 10px;
        letter-spacing: 1px;
      }

      .badge-guest {
        background: rgba(58, 107, 138, 0.3);
        color: var(--muted);
        border: 1px solid var(--muted);
      }
      .badge-user {
        background: rgba(0, 212, 255, 0.1);
        color: var(--accent);
        border: 1px solid var(--accent);
      }
      .badge-admin {
        background: rgba(255, 204, 0, 0.1);
        color: var(--accent3);
        border: 1px solid var(--accent3);
      }

      .token-panel {
        border: 1px solid var(--border);
        background: var(--panel);
        padding: 24px;
        margin-bottom: 20px;
        position: relative;
      }

      .token-panel::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 3px;
        height: 100%;
        background: linear-gradient(180deg, var(--accent3), transparent);
      }

      .token-raw {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.72rem;
        word-break: break-all;
        line-height: 1.6;
        background: rgba(0, 0, 0, 0.4);
        padding: 14px;
        border: 1px solid rgba(13, 58, 92, 0.5);
        color: #5a9fc0;
        margin-bottom: 16px;
        cursor: pointer;
        transition: border-color 0.2s;
      }

      .token-raw:hover {
        border-color: var(--accent);
      }

      .token-parts {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 16px;
      }

      .token-part {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.72rem;
        padding: 10px 14px;
        border-left: 3px solid;
      }

      .token-part.header {
        border-color: #ff6b6b;
        background: rgba(255, 107, 107, 0.06);
      }
      .token-part.payload {
        border-color: #ffd93d;
        background: rgba(255, 217, 61, 0.06);
      }
      .token-part.sig {
        border-color: #6bcb77;
        background: rgba(107, 203, 119, 0.06);
      }

      .token-part-label {
        font-size: 0.65rem;
        letter-spacing: 2px;
        opacity: 0.7;
        margin-bottom: 6px;
      }

      .token-part.header .token-part-label {
        color: #ff6b6b;
      }
      .token-part.payload .token-part-label {
        color: #ffd93d;
      }
      .token-part.sig .token-part-label {
        color: #6bcb77;
      }

      .token-json {
        color: #c0d8e8;
        white-space: pre-wrap;
      }

      .alert-box {
        border: 1px solid rgba(255, 204, 0, 0.4);
        background: rgba(255, 204, 0, 0.05);
        padding: 16px 20px;
        margin-bottom: 20px;
        display: flex;
        gap: 12px;
        align-items: flex-start;
      }

      .alert-icon {
        font-size: 1.1rem;
        flex-shrink: 0;
        margin-top: 1px;
      }

      .alert-text {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.78rem;
        color: var(--accent3);
        line-height: 1.7;
        letter-spacing: 0.5px;
      }

      .locked-panel {
        border: 1px solid rgba(255, 68, 68, 0.3);
        background: rgba(255, 68, 68, 0.03);
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .locked-icon {
        font-size: 2rem;
      }

      .locked-text {
        font-family: "Share Tech Mono", monospace;
      }

      .locked-text strong {
        display: block;
        color: var(--accent2);
        font-size: 0.85rem;
        letter-spacing: 2px;
        margin-bottom: 4px;
      }

      .locked-text span {
        font-size: 0.75rem;
        color: var(--muted);
      }

      .copy-hint {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.7rem;
        color: var(--muted);
        text-align: right;
        margin-top: 6px;
      }

      .btn {
        font-family: "Orbitron", monospace;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 2px;
        padding: 10px 20px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.2s;
      }

      .btn-primary {
        background: var(--accent);
        color: #000;
      }
      .btn-primary:hover {
        background: #fff;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="logo">ARIA<span>.</span>CORP</div>
        <nav>
          <a href="/">홈</a>
          <a href="/admin">관리자 패널</a>
          <a href="/logout">로그아웃</a>
        </nav>
      </div>
    </header>

    <div class="main">
      <div class="page-title">USER DASHBOARD</div>
      <div class="page-sub">
        // AUTHENTICATED SESSION · <%= user.username.toUpperCase() %>
      </div>

      <div class="alert-box">
        <div class="alert-icon">⚠</div>
        <div class="alert-text">
          현재 권한 레벨로는 기밀 파일 보관소에 접근할 수 없습니다.<br />
          <strong>/admin</strong> 경로는 <strong>관리자(admin) 권한</strong>이
          있어야만 접근 가능합니다.<br />
          당신의 현재 역할: <strong><%= user.role.toUpperCase() %></strong>
        </div>
      </div>

      <div class="grid">
        <div class="panel">
          <div class="panel-label">// ACCOUNT INFO</div>
          <div class="info-row">
            <div class="info-key">USERNAME</div>
            <div class="info-val"><%= user.username %></div>
          </div>
          <div class="info-row">
            <div class="info-key">ROLE</div>
            <div class="info-val">
              <span class="badge badge-<%= user.role %>"
                ><%= user.role.toUpperCase() %></span
              >
            </div>
          </div>
          <div class="info-row">
            <div class="info-key">STATUS</div>
            <div class="info-val" style="color: #6bcb77">● ACTIVE</div>
          </div>
          <div class="info-row">
            <div class="info-key">BIO</div>
            <div
              class="info-val"
              style="font-size: 0.75rem; color: var(--muted)"
            >
              <%= bio %>
            </div>
          </div>
        </div>

        <div class="locked-panel">
          <div class="locked-icon">🔒</div>
          <div class="locked-text">
            <strong>ACCESS RESTRICTED</strong>
            <span
              >관리자 패널(/admin)은 권한이 없어 접근할 수 없습니다. 어떻게 하면
              관리자가 될 수 있을까요?</span
            >
          </div>
        </div>
      </div>

      <div class="token-panel">
        <div class="panel-label">// 시스템 계정 인증 토큰 (JWT)</div>

        <div class="token-raw" onclick="copyToken()" title="클릭하여 복사">
          <%= token %>
        </div>
        <div class="copy-hint">▲ 클릭하면 클립보드에 복사됩니다</div>

        <br />
        <div class="token-parts" id="tokenParts"></div>
      </div>
    </div>

    <script>
      const rawToken = `<%= token %>`;

      function base64urlDecode(str) {
        str = str.replace(/-/g, "+").replace(/_/g, "/");
        while (str.length % 4) str += "=";
        try {
          return JSON.parse(atob(str));
        } catch {
          return atob(str);
        }
      }

      function renderToken() {
        const parts = rawToken.split(".");
        if (parts.length < 3) return;

        const header = base64urlDecode(parts[0]);
        const payload = base64urlDecode(parts[1]);

        const container = document.getElementById("tokenParts");
        container.innerHTML = `
      <div class="token-part header">
        <div class="token-part-label">HEADER (Base64URL decoded)</div>
        <div class="token-json">${JSON.stringify(header, null, 2)}</div>
      </div>
      <div class="token-part payload">
        <div class="token-part-label">PAYLOAD (Base64URL decoded)</div>
        <div class="token-json">${JSON.stringify(payload, null, 2)}</div>
      </div>
      <div class="token-part sig">
        <div class="token-part-label">SIGNATURE</div>
        <div class="token-json">${parts[2]}</div>
      </div>
    `;
      }

      function copyToken() {
        navigator.clipboard.writeText(rawToken).then(() => {
          const el = document.querySelector(".token-raw");
          el.style.borderColor = "var(--accent)";
          el.style.color = "var(--accent)";
          setTimeout(() => {
            el.style.borderColor = "";
            el.style.color = "";
          }, 800);
        });
      }

      renderToken();
    </script>
  </body>
</html>
